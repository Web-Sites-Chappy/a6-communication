# Normalize line endings to LF on checkin and checkout
* text=auto eol=lf

# Binary assets — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.mp4   binary
*.webm  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
